# Production build secrets for rev-dep.
#
# Copy this file to cli-telemetry.env (which is git-ignored) and fill in the real value.
# scripts/buildProdBinaries.sh reads it and bakes the values into the published binaries.
#
# The value MUST be wrapped in double quotes - the connection string contains ';', which the shell
# would otherwise treat as a command separator.

REVDEP_TELEMETRY_CONNECTION_STRING="InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/"
